# Test Database Configuration
# This file stores the test database URL for integration and E2E tests
# Replace with your actual test database URL from Render.com or local PostgreSQL

# Test Database URL (PostgreSQL)
# Format: postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/steelworks_test_db

# Alternative: Individual test database parameters
DB_HOST=localhost
DB_PORT=5432
DB_NAME=steelworks_test_db
DB_USER=postgres
DB_PASSWORD=postgres
